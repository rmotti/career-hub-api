{
  "name": "fc26-career-hub-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch --env-file=.env.local src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-competitions": "tsx prisma/seed-competitions.ts",
    "db:migrate-data": "tsx prisma/migrate-data.ts",
    "db:studio": "prisma studio",
    "db:seed-fc26": "tsx scripts/seed-fc26.ts",
    "fit-score:clubs:sync": "tsx scripts/sync-fit-score-club-aliases.ts",
    "fit-score:clubs": "tsx scripts/generate-fit-score-club-alias-report.ts"
  },
  "dependencies": {
    "@fastify/compress": "^6.5.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.2",
    "csv-parse": "^6.2.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
