# Railway DB — URL publica para desenvolvimento local/Prisma CLI
DATABASE_URL="postgresql://user:password@host.proxy.rlwy.net:port/railway"

# Railway DB — URL direta para migrations
DIRECT_URL="postgresql://user:password@host.proxy.rlwy.net:port/railway"

PORT=3333

# Better Auth — gere um secret forte: openssl rand -base64 32
BETTER_AUTH_SECRET="seu-secret-aqui"
BETTER_AUTH_URL="https://sua-api.vercel.app"

# Origens permitidas para CORS e Better Auth (separadas por vírgula)
TRUSTED_ORIGINS="https://seu-frontend.vercel.app,https://fc-26-career-hub.vercel.app,https://fc-26-career-hub-*.vercel.app,https://fc-career-*.vercel.app,https://sua-api.vercel.app,http://localhost:8080"

# Redis — use redis://localhost:6379 para dev local
REDIS_URL="redis://localhost:6379"

# Serviço externo de fit score
FIT_SCORE_SERVICE_URL="https://fit-score-svc-production.up.railway.app"
