# Neon DB — URL com pooler (usada pelo Prisma em runtime via pgbouncer)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Neon DB — URL direta (usada pelo Prisma para migrations)
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

PORT=3333

# Better Auth — gere um secret forte: openssl rand -base64 32
BETTER_AUTH_SECRET="seu-secret-aqui"
BETTER_AUTH_URL="https://sua-api.vercel.app"

# Origens permitidas para CORS e Better Auth (separadas por vírgula)
TRUSTED_ORIGINS="https://seu-frontend.vercel.app,https://sua-api.vercel.app,http://localhost:8080"

# Redis — use redis://localhost:6379 para dev local
REDIS_URL="redis://localhost:6379"
