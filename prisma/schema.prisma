generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth models (Better Auth) ─────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String    @default("user")
  plan          UserPlan  @default(FREE)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  saves         Save[]
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

enum UserPlan {
  FREE
  PRO
  PREMIUM
}

// ── App models ────────────────────────────────────────────────────────────────

model Save {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  currentYear    Int         @default(2025)
  currentSeason  String      @default("2025/26")
  budget         Float?
  balance        Float?
  clubStints     ClubStint[]
  players        Player[]
  transfers      Transfer[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model ClubStint {
  id               String             @id @default(uuid())
  saveId           String
  save             Save               @relation(fields: [saveId], references: [id], onDelete: Cascade)
  club             String
  startYear        String
  endYear          String?
  isCurrent        Boolean            @default(true)
  playerSeasonStats PlayerSeasonStats[]
  teamSeasonStats  TeamSeasonStats[]
  trophies         Trophy[]
  transfers        Transfer[]
  players          Player[]           @relation("ActiveClubStint")
  createdAt        DateTime           @default(now())

  @@index([saveId])
  @@index([saveId, isCurrent])
}

model Player {
  id                String             @id @default(uuid())
  saveId            String
  save              Save               @relation(fields: [saveId], references: [id], onDelete: Cascade)
  activeClubStintId String?
  activeClubStint   ClubStint?         @relation("ActiveClubStint", fields: [activeClubStintId], references: [id])
  name              String
  position          Position
  age               Int
  status            PlayerStatus
  ovr               Int
  potential         Int?
  shirtNumber       Int?
  nation            String?
  salary            Float?
  marketValue       Float?
  seasonStats       PlayerSeasonStats[]
  ovrHistory        PlayerOvrHistory[]
  transfers         Transfer[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([saveId])
  @@index([saveId, activeClubStintId])
}

model PlayerOvrHistory {
  id          String   @id @default(uuid())
  playerId    String
  season      String
  ovr         Int
  marketValue Float?
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, season])
  @@index([playerId, createdAt(sort: Desc)])
}

model PlayerSeasonStats {
  id           String    @id @default(uuid())
  playerId     String
  player       Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubStintId  String
  clubStint    ClubStint @relation(fields: [clubStintId], references: [id], onDelete: Cascade)
  season       String
  goals        Int       @default(0)
  assists      Int       @default(0)
  matches      Int       @default(0)
  yellowCards  Int       @default(0)
  redCards     Int       @default(0)
  cleanSheets  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([playerId, clubStintId, season])
  @@index([clubStintId, season])
}

model Competition {
  id        String          @id @default(uuid())
  name      String          @unique
  type      CompetitionType
  country   String?

  teamStats TeamSeasonStats[]
  trophies  Trophy[]
}

model TeamSeasonStats {
  id                  String       @id @default(uuid())
  clubStintId         String
  clubStint           ClubStint    @relation(fields: [clubStintId], references: [id], onDelete: Cascade)
  competitionId       String?
  competition         Competition? @relation(fields: [competitionId], references: [id])
  season              String
  goalsPro            Int          @default(0)
  goalsAgainst        Int          @default(0)
  wins                Int          @default(0)
  draws               Int          @default(0)
  losses              Int          @default(0)
  leaguePosition      Int?
  // deprecated — migrar para cupResult via prisma/migrate-data.ts
  europeanCupResult   CupResult    @default(NaoParticipou)
  nationalCupResult   CupResult    @default(NaoParticipou)
  cupResult           CupResult?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([clubStintId, competitionId, season])
  @@index([clubStintId, season])
}

model Transfer {
  id           String       @id @default(uuid())
  saveId       String
  save         Save         @relation(fields: [saveId], references: [id], onDelete: Cascade)
  clubStintId  String?
  clubStint    ClubStint?   @relation(fields: [clubStintId], references: [id])
  playerId     String?
  player       Player?      @relation(fields: [playerId], references: [id])
  playerName   String
  type         TransferType
  from         String
  to           String
  fee          Float?
  season       String
  createdAt    DateTime     @default(now())

  @@index([saveId])
  @@index([saveId, season])
  @@index([clubStintId, season])
}

model Trophy {
  id            String       @id @default(uuid())
  clubStintId   String
  clubStint     ClubStint    @relation(fields: [clubStintId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id])
  name          String?      // deprecated — removido após migrate-data.ts
  year          Int
  createdAt     DateTime     @default(now())

  @@unique([clubStintId, competitionId, year])
}

enum Position {
  GOL
  LD
  LE
  ZAG
  VOL
  MC
  ME
  MD
  MEI
  PE
  PD
  SA
  ATA
}

enum PlayerStatus {
  Crucial
  Important
  Role
  Sporadic
  Promising
  Loan
}

enum TransferType {
  compra
  venda
  emprestimo_entrada
  emprestimo_saida
}

enum CupResult {
  Campeao
  Final
  Semifinal
  Quartas
  OitavasOuFaseDeGrupos
  Eliminado
  NaoParticipou
}

enum CompetitionType {
  League
  NationalCup
  SuperCup
  EuropeanCup
}
