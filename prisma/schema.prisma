generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String    @default("user")
  plan          UserPlan  @default(FREE)
  createdAt     DateTime
  updatedAt     DateTime
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  accounts      Account[]
  saves         Save[]
  sessions      Session[]
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model Save {
  id            String      @id @default(uuid())
  name          String
  currentYear   Int         @default(2026)
  currentSeason String      @default("2026/27")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  budget        Float?
  balance       Float?
  userId        String
  clubStints    ClubStint[]
  players       Player[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transfers     Transfer[]
}

model ClubStint {
  id                String              @id @default(uuid())
  saveId            String
  club              String
  startYear         String
  endYear           String?
  isCurrent         Boolean             @default(true)
  createdAt         DateTime            @default(now())
  save              Save                @relation(fields: [saveId], references: [id], onDelete: Cascade)
  players           Player[]            @relation("ActiveClubStint")
  playerSeasonStats PlayerSeasonStats[]
  teamSeasonStats   TeamSeasonStats[]
  transfers         Transfer[]
  trophies          Trophy[]

  @@index([saveId])
  @@index([saveId, isCurrent])
}

model Player {
  id                String              @id @default(uuid())
  saveId            String
  activeClubStintId String?
  name              String
  position          Position
  age               Int
  status            PlayerStatus
  ovr               Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  salary            Float?
  marketValue       Float?
  potential         Int?
  shirtNumber       Int?
  nation            String?
  alternativePosition Json                @default("{\"positions\":[]}")
  activeClubStint   ClubStint?          @relation("ActiveClubStint", fields: [activeClubStintId], references: [id])
  save              Save                @relation(fields: [saveId], references: [id], onDelete: Cascade)
  ovrHistory        PlayerOvrHistory[]
  seasonStats       PlayerSeasonStats[]
  transfers         Transfer[]

  @@index([saveId])
  @@index([saveId, activeClubStintId])
}

model PlayerOvrHistory {
  id          String   @id @default(uuid())
  playerId    String
  season      String
  ovr         Int
  marketValue Float?
  createdAt   DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, season])
  @@index([playerId, createdAt(sort: Desc)])
}

model PlayerSeasonStats {
  id          String    @id @default(uuid())
  playerId    String
  clubStintId String
  season      String
  goals       Int       @default(0)
  assists     Int       @default(0)
  yellowCards Int       @default(0)
  redCards    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  matches     Int       @default(0)
  cleanSheets Int       @default(0)
  clubStint   ClubStint @relation(fields: [clubStintId], references: [id], onDelete: Cascade)
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, clubStintId, season])
  @@index([clubStintId, season])
}

model Competition {
  id        String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String            @unique
  type      CompetitionType
  country   String?
  teamStats TeamSeasonStats[]
  trophies  Trophy[]
}

model TeamSeasonStats {
  id                String       @id @default(uuid())
  clubStintId       String
  season            String
  goalsPro          Int          @default(0)
  goalsAgainst      Int          @default(0)
  wins              Int          @default(0)
  draws             Int          @default(0)
  losses            Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  europeanCupResult CupResult    @default(NaoParticipou)
  leaguePosition    Int?
  nationalCupResult CupResult    @default(NaoParticipou)
  competitionId     String?
  cupResult         CupResult?
  clubStint         ClubStint    @relation(fields: [clubStintId], references: [id], onDelete: Cascade)
  competition       Competition? @relation(fields: [competitionId], references: [id])

  @@unique([clubStintId, competitionId, season])
}

model Transfer {
  id          String       @id @default(uuid())
  saveId      String
  playerId    String?
  playerName  String
  type        TransferType
  from        String
  to          String
  season      String
  createdAt   DateTime     @default(now())
  fee         Float?
  clubStintId String?
  clubStint   ClubStint?   @relation(fields: [clubStintId], references: [id])
  player      Player?      @relation(fields: [playerId], references: [id])
  save        Save         @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@index([saveId])
  @@index([saveId, season])
  @@index([clubStintId, season])
}

model Trophy {
  id            String       @id @default(uuid())
  clubStintId   String
  name          String?
  year          Int
  createdAt     DateTime     @default(now())
  competitionId String?
  clubStint     ClubStint    @relation(fields: [clubStintId], references: [id], onDelete: Cascade)
  competition   Competition? @relation(fields: [competitionId], references: [id])

  @@unique([clubStintId, competitionId, year])
}

model Fc26Player {
  id          Int      @id @default(autoincrement())
  sofifaId    Int      @unique
  name        String
  longName    String?
  positions   String[]
  age         Int
  dob         String?
  height      Int?
  weight      Int?
  ovr         Int
  potential   Int
  marketValue Float?
  nation      String?
  club        String?
  league      String?
  wage        Float?
  playerFaceUrl String?

  // Contract
  contractUntil Int?
  releaseClause Float?

  // Player attributes
  preferredFoot           String?
  weakFoot                Int?
  skillMoves              Int?
  internationalReputation Int?
  workRate                String?
  bodyType                String?
  playerTags              String[]
  playerTraits            String[]

  // Overall ratings
  pace      Int?
  shooting  Int?
  passing   Int?
  dribbling Int?
  defending Int?
  physic    Int?

  // Attacking
  attackingCrossing        Int?
  attackingFinishing       Int?
  attackingHeadingAccuracy Int?
  attackingShortPassing    Int?
  attackingVolleys         Int?

  // Skill
  skillDribbling   Int?
  skillCurve       Int?
  skillFkAccuracy  Int?
  skillLongPassing Int?
  skillBallControl Int?

  // Movement
  movementAcceleration Int?
  movementSprintSpeed  Int?
  movementAgility      Int?
  movementReactions    Int?
  movementBalance      Int?

  // Power
  powerShotPower Int?
  powerJumping   Int?
  powerStamina   Int?
  powerStrength  Int?
  powerLongShots Int?

  // Mentality
  mentalityAggression    Int?
  mentalityInterceptions Int?
  mentalityPositioning   Int?
  mentalityVision        Int?
  mentalityPenalties     Int?
  mentalityComposure     Int?

  // Defending
  defendingMarkingAwareness Int?
  defendingStandingTackle   Int?
  defendingSlidingTackle    Int?

  // Goalkeeping
  goalkeepingDiving      Int?
  goalkeepingHandling    Int?
  goalkeepingKicking     Int?
  goalkeepingPositioning Int?
  goalkeepingReflexes    Int?
  goalkeepingSpeed       Int?

  @@index([ovr])
  @@index([potential])
  @@index([age])
  @@index([nation])
  @@index([league])
  @@index([pace])
  @@index([preferredFoot])
  @@index([positions], type: Gin)
  @@index([playerTags], type: Gin)
  @@index([playerTraits], type: Gin)
}

enum UserPlan {
  FREE
  PRO
  PREMIUM
}

enum Position {
  GOL
  ZAG
  MEI
  ATA
  LD
  LE
  VOL
  MC
  ME
  MD
  PE
  PD
  SA
}

enum PlayerStatus {
  Crucial
  Important
  Role
  Sporadic
  Promising
  Loan
}

enum TransferType {
  compra
  venda
  emprestimo_entrada
  emprestimo_saida
}

enum CupResult {
  Campeao
  Final
  Semifinal
  Quartas
  OitavasOuFaseDeGrupos
  Eliminado
  NaoParticipou
}

enum CompetitionType {
  League
  NationalCup
  SuperCup
  EuropeanCup
}
