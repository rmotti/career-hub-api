{
  "title": "k6 Load Testing Results",
  "uid": "k6-career-hub",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "Virtual Users",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2, "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "Requests/s",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT count(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time(1s) fill(0)" }],
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 3, "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "Error Rate",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"http_req_failed\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 4, "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "p95 Latência Geral",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 2000 }] } } }
    },

    {
      "id": 5, "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "type": "timeseries", "title": "Latência p95 por Endpoint",
      "datasource": "InfluxDB",
      "targets": [
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"login_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Login" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"list_saves_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "List Saves" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"create_save_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Create Save" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"list_players_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "List Players" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"create_player_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Create Player" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"update_player_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Update Player" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"update_player_stats_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Update Stats" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"transfer_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Transfer" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"advance_season_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Advance Season" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"change_club_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Change Club" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"team_stats_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Team Stats" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"trophy_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Trophy" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },

    {
      "id": 6, "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "type": "timeseries", "title": "Virtual Users ao longo do tempo",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "VUs" }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 20 }, "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },
    {
      "id": 7, "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "type": "timeseries", "title": "Requests/s ao longo do tempo",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT count(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "alias": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },

    {
      "id": 8, "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "type": "timeseries", "title": "Taxa de Erros por Operação (%)",
      "datasource": "InfluxDB",
      "targets": [
        { "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"login_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Login Errors" },
        { "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"create_save_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Create Save Errors" },
        { "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"create_player_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Create Player Errors" },
        { "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"transfer_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Transfer Errors" },
        { "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"advance_season_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Advance Season Errors" },
        { "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"change_club_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "Change Club Errors" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2 }, "min": 0, "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 9, "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 },
      "type": "text", "title": "",
      "options": { "mode": "markdown", "content": "## Leituras (Read Operations)" }
    },
