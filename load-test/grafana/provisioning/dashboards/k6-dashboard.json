{
  "title": "k6 Load Testing Results",
  "uid": "k6-career-hub",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "Virtual Users",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2, "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "Requests/s",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT non_negative_derivative(max(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 3, "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "Error Rate",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT mean(\"value\") * 100 FROM \"http_req_failed\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 4, "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "type": "stat", "title": "p95 Latência Geral",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 2000 }] } } }
    },
    {
      "id": 5, "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "type": "timeseries", "title": "Latência por Endpoint (p95)",
      "datasource": "InfluxDB",
      "targets": [
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "http_req_duration p95" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"login_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "login p95" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"list_saves_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "list_saves p95" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"create_save_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "create_save p95" },
        { "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"list_players_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "list_players p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 6, "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "type": "timeseries", "title": "Virtual Users ao longo do tempo",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "VUs" }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 20 }, "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },
    {
      "id": 7, "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "type": "timeseries", "title": "Requests/s ao longo do tempo",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT non_negative_derivative(max(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(null)", "alias": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 8, "gridPos": { "x": 0, "y": 20, "w": 8, "h": 4 },
      "type": "stat", "title": "p95 Login",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"login_duration\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 3000 }] } } }
    },
    {
      "id": 9, "gridPos": { "x": 8, "y": 20, "w": 8, "h": 4 },
      "type": "stat", "title": "p95 List Saves",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"list_saves_duration\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1000 }] } } }
    },
    {
      "id": 10, "gridPos": { "x": 16, "y": 20, "w": 8, "h": 4 },
      "type": "stat", "title": "p95 Create Save",
      "datasource": "InfluxDB",
      "targets": [{ "rawQuery": true, "query": "SELECT percentile(\"value\", 95) FROM \"create_save_duration\" WHERE $timeFilter" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1500 }] } } }
    }
  ]
}
